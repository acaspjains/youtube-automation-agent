# YouTube Automation Agent Environment Configuration
# RozKiKahani - @RozKiKahanibysp
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to GitHub

# AI Provider - Gemini Free Tier (recommended)
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# MOONSHOT_API_KEY=your-kimi-api-key-here

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-data-api-key-here

# ElevenLabs TTS (optional, higher quality voice)
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# ELEVENLABS_VOICE_ID=your-voice-id-here

# Replicate (optional, for AI video generation)
# REPLICATE_API_KEY=your-replicate-api-key-here

# Azure Speech TTS (optional alternative)
# AZURE_SPEECH_KEY=your-azure-speech-key-here
# AZURE_SPEECH_REGION=eastus

# Application Settings
NODE_ENV=production
PORT=3456
LOG_LEVEL=info

# Channel Settings
CHANNEL_NAME=RozKiKahani
CHANNEL_HANDLE=@RozKiKahanibysp
DEFAULT_AUTHOR=RozKiKahani
TARGET_AUDIENCE=Middle class Indians aged 20-40 who relate to real daily life stories about money struggles, career challenges, family relationships, emotions and dreams
NICHE=daily life stories - money, career, family, emotions, dreams, success comebacks
LANGUAGE=Hinglish
VIDEO_STYLE=emotional storytelling, real people real stories, relatable middle class India
TAGLINE=Yeh meri bhi kahani hai

# YouTube Settings
YOUTUBE_REGION=IN
DEFAULT_PRIVACY_STATUS=public

# Content Settings
AUTO_SHORTEN_CONTENT=true
AUTO_ADD_BACKLINKS=true
PRESERVE_FORMATTING=true
AUTO_RESIZE_IMAGES=true
MAX_IMAGE_WIDTH=1280
MAX_IMAGE_HEIGHT=720
IMAGE_QUALITY=90

# Posting Schedule
POSTING_FREQUENCY=daily
POST_TIME=09:00
POST_TIMEZONE=Asia/Kolkata

# Rate Limiting
GLOBAL_RATE_LIMIT_PER_HOUR=50
DEFAULT_DELAY_BETWEEN_POSTS=60000

# Security
JWT_SECRET=generate-a-random-secret-here

# Analytics & Monitoring
ENABLE_ANALYTICS=true
ANALYTICS_DB_PATH=./data/analytics.db

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# Error Handling
RETRY_ATTEMPTS=3
RETRY_DELAY=5000

# Human Fingerprint (anti-ban safety)
ADD_HUMAN_OPINION=true
ROTATE_NICHES=true
AI_DISCLOSURE=true
MAX_VIDEOS_PER_DAY=1

